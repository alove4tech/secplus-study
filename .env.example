# SecPlus Study App Environment Variables
# Copy this file to .env and update with your values
# DO NOT commit .env to git!

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================

# Node environment (development | production)
NODE_ENV=production

# Application port
PORT=3000

# ==============================================================================
# OPTIONAL: DATABASE / BACKEND (if you add persistence later)
# ==============================================================================

# Example for PostgreSQL (optional - currently not used)
# DATABASE_URL=postgresql://user:password@host:5432/secplus

# Example for external API (optional)
# API_BASE_URL=https://api.example.com
# API_KEY=your_api_key_here

# ==============================================================================
# OPTIONAL: ANALYTICS (if you want to add tracking)
# ==============================================================================

# Example for analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ==============================================================================
# OPTIONAL: FEATURES (for future enhancements)
# ==============================================================================

# Enable progress tracking (requires backend)
# ENABLE_TRACKING=false

# Enable user accounts (requires backend)
# ENABLE_AUTH=false
